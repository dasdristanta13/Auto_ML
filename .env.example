# Copy to .env and fill in whichever provider(s) you configured in config/models.yaml.
# Only the keys for providers actually referenced in models.yaml are required.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Set to 1 to run the entire pipeline + web UI with canned LLM responses —
# no API keys or network needed. Great for local testing/demo.
AUTOML_MOCK_LLM=
